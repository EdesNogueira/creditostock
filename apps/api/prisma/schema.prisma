generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  ANALYST
  VIEWER
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  IGNORED
}

enum IssueSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MatchType {
  EXACT_SKU
  EXACT_EAN
  ALIAS
  FUZZY_DESCRIPTION_NCM
  MANUAL
}

enum AllocationStrategy {
  FIFO
  MANUAL
}

enum CalculationMode {
  STRICT
  ASSISTED
  SIMULATION
}

enum CalculationStatus {
  PENDING
  RUNNING
  DONE
  ERROR
}

enum DossierStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum JobStatus {
  QUEUED
  PROCESSING
  DONE
  FAILED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  IMPORT
  MANUAL_LINK
  CALCULATE
  APPROVE
  REJECT
}

enum TaxRegime {
  UNKNOWN
  NORMAL
  ST
}

enum CalculationKind {
  GENERAL_ICMS
  ST_TRANSITION
}

enum TransitionCalcMethod {
  PROPORTIONAL_ST_ONLY
  PROPORTIONAL_ST_PLUS_FCP
  MANUAL_OVERRIDE
}

enum TransitionCreditStatus {
  OPEN
  PARTIALLY_USED
  FULLY_USED
  BLOCKED
}

enum LedgerEntryType {
  GENERATED
  MANUAL_ADJUSTMENT
  USED
  BLOCKED
  REVERSED
}

// ─── Core Entities ───────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  cnpj        String   @unique
  tradeName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branches    Branch[]
  users       User[]
  auditLogs   AuditLog[]

  @@map("companies")
}

model Branch {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  cnpj        String   @unique
  address     String?
  city        String?
  state       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company               Company                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockSnapshots        StockSnapshot[]
  nfeDocuments          NfeDocument[]
  calculations          CreditCalculation[]
  dossiers              Dossier[]
  transitionCreditLots  TransitionCreditLot[]
  transitionLedger      TransitionCreditLedgerEntry[]

  @@map("branches")
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(ANALYST)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  auditLogs  AuditLog[]

  @@map("users")
}

model Product {
  id           String   @id @default(cuid())
  companyId    String?
  sku          String
  ean          String?
  description  String
  ncm          String?
  unit         String   @default("UN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  aliases             ProductAlias[]
  stockSnapshotItems  StockSnapshotItem[]
  nfeItems            NfeItem[]
  productMatches      ProductMatch[]

  @@unique([companyId, sku])
  @@index([sku])
  @@index([ean])
  @@index([ncm])
  @@map("products")
}

model ProductAlias {
  id          String  @id @default(cuid())
  productId   String
  aliasType   String
  aliasValue  String
  sourceNote  String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([aliasType, aliasValue])
  @@map("product_aliases")
}

// ─── Stock Snapshot ───────────────────────────────────────────────────────────

model StockSnapshot {
  id           String    @id @default(cuid())
  branchId     String
  referenceDate DateTime
  importedAt   DateTime  @default(now())
  fileName     String
  storageKey   String?
  fileHash     String?
  totalItems   Int       @default(0)
  parserVersion String?
  importSource  String?
  jobStatus    JobStatus @default(QUEUED)
  jobError     String?

  branch  Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items   StockSnapshotItem[]
  transitionCreditLots TransitionCreditLot[]

  @@index([branchId])
  @@map("stock_snapshots")
}

model StockSnapshotItem {
  id              String  @id @default(cuid())
  snapshotId      String
  productId       String?
  rawSku          String
  rawEan          String?
  rawDescription  String
  rawNcm          String?
  quantity        Decimal @db.Decimal(14, 4)
  unitCost        Decimal @db.Decimal(14, 4)
  totalCost       Decimal @db.Decimal(14, 4)
  unit            String  @default("UN")

  snapshot           StockSnapshot         @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  product            Product?              @relation(fields: [productId], references: [id])
  productMatches     ProductMatch[]
  originAllocations  StockOriginAllocation[]
  issues             Issue[]
  transitionCreditLots TransitionCreditLot[]

  @@index([snapshotId])
  @@index([rawSku])
  @@map("stock_snapshot_items")
}

// ─── NF-e ─────────────────────────────────────────────────────────────────────

model NfeDocument {
  id                String   @id @default(cuid())
  branchId          String
  chaveAcesso       String   @unique
  numero            String
  serie             String
  dataEmissao       DateTime
  cnpjEmitente      String
  nomeEmitente      String
  cnpjDestinatario  String
  valorTotal        Decimal  @db.Decimal(14, 2)
  emitState         String?
  destState         String?
  operationNature   String?
  rawProtocolNumber String?
  rawAdditionalInfo String?  @db.Text
  storageKey        String?
  rawXml            String?  @db.Text
  xmlHash           String?
  parserVersion     String?
  importSource      String?
  importedAt        DateTime @default(now())
  jobStatus         JobStatus @default(QUEUED)
  jobError          String?

  branch  Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  items   NfeItem[]

  @@index([branchId])
  @@index([cnpjEmitente])
  @@index([dataEmissao])
  @@map("nfe_documents")
}

model NfeItem {
  id            String   @id @default(cuid())
  nfeDocumentId String
  productId     String?
  nItem         Int?
  cProd         String
  xProd         String
  cEan          String?
  ncm           String?
  cest          String?
  cfop          String
  uCom          String
  qCom          Decimal  @db.Decimal(14, 4)
  vUnCom        Decimal  @db.Decimal(14, 4)
  vProd         Decimal  @db.Decimal(14, 2)

  // ICMS regular
  orig          String?
  cst           String?
  csosn         String?
  modBC         String?
  vBC           Decimal  @db.Decimal(14, 2) @default(0)
  pIcms         Decimal  @db.Decimal(8, 4)  @default(0)
  vIcms         Decimal  @db.Decimal(14, 2) @default(0)

  // ICMS-ST
  modBCST       String?
  pMVAST        Decimal  @db.Decimal(8, 4)  @default(0)
  vBCST         Decimal  @db.Decimal(14, 2) @default(0)
  pICMSST       Decimal  @db.Decimal(8, 4)  @default(0)
  vICMSST       Decimal  @db.Decimal(14, 2) @default(0)

  // FCP-ST
  vBCFCPST      Decimal  @db.Decimal(14, 2) @default(0)
  pFCPST        Decimal  @db.Decimal(8, 4)  @default(0)
  vFCPST        Decimal  @db.Decimal(14, 2) @default(0)

  // Calculated unit amounts
  taxRegime         TaxRegime @default(UNKNOWN)
  stApplies         Boolean   @default(false)
  icmsUnitAmount    Decimal   @db.Decimal(14, 6) @default(0)
  icmsStUnitAmount  Decimal   @db.Decimal(14, 6) @default(0)
  fcpStUnitAmount   Decimal   @db.Decimal(14, 6) @default(0)

  // Metadata
  supplierOrderRef  String?
  extIpi            String?
  rawTaxJson        Json?

  nfeDocument        NfeDocument           @relation(fields: [nfeDocumentId], references: [id], onDelete: Cascade)
  product            Product?              @relation(fields: [productId], references: [id])
  productMatches     ProductMatch[]
  originAllocations  StockOriginAllocation[]
  transitionCreditLots TransitionCreditLot[]

  @@unique([nfeDocumentId, nItem])
  @@index([cProd])
  @@index([ncm])
  @@index([cest])
  @@index([cfop])
  @@index([cst])
  @@index([nfeDocumentId])
  @@map("nfe_items")
}

// ─── Matching ────────────────────────────────────────────────────────────────

model ProductMatch {
  id                  String    @id @default(cuid())
  stockSnapshotItemId String
  nfeItemId           String
  productId           String?
  matchType           MatchType
  confidence          Float     @default(1.0)
  isConfirmed         Boolean   @default(false)
  confirmedAt         DateTime?
  confirmedBy         String?
  notes               String?
  createdAt           DateTime  @default(now())

  stockSnapshotItem StockSnapshotItem @relation(fields: [stockSnapshotItemId], references: [id], onDelete: Cascade)
  nfeItem           NfeItem           @relation(fields: [nfeItemId], references: [id], onDelete: Cascade)
  product           Product?          @relation(fields: [productId], references: [id])

  @@map("product_matches")
}

// ─── Origin Allocation ───────────────────────────────────────────────────────

model StockOriginAllocation {
  id                    String             @id @default(cuid())
  stockSnapshotItemId   String
  nfeItemId             String
  strategy              AllocationStrategy @default(FIFO)
  allocatedQty          Decimal            @db.Decimal(14, 4)
  allocatedCost         Decimal            @db.Decimal(14, 4)
  allocatedIcms         Decimal            @db.Decimal(14, 4)
  isManual              Boolean            @default(false)
  manualReason          String?

  // ST-specific allocation fields
  sourceTaxRegime       TaxRegime          @default(UNKNOWN)
  allocatedRegularIcms  Decimal            @db.Decimal(14, 4) @default(0)
  allocatedIcmsSt       Decimal            @db.Decimal(14, 4) @default(0)
  allocatedFcpSt        Decimal            @db.Decimal(14, 4) @default(0)
  unitRegularIcms       Decimal            @db.Decimal(14, 6) @default(0)
  unitIcmsSt            Decimal            @db.Decimal(14, 6) @default(0)
  unitFcpSt             Decimal            @db.Decimal(14, 6) @default(0)
  taxTransitionRuleId   String?
  calcNotes             String?

  createdAt             DateTime           @default(now())

  stockSnapshotItem     StockSnapshotItem  @relation(fields: [stockSnapshotItemId], references: [id], onDelete: Cascade)
  nfeItem               NfeItem            @relation(fields: [nfeItemId], references: [id], onDelete: Cascade)
  taxTransitionRule     TaxTransitionRule?  @relation(fields: [taxTransitionRuleId], references: [id])

  @@index([stockSnapshotItemId])
  @@index([nfeItemId])
  @@index([taxTransitionRuleId])
  @@map("stock_origin_allocations")
}

// ─── Tax Rules (general) ─────────────────────────────────────────────────────

model TaxRule {
  id          String  @id @default(cuid())
  name        String
  description String?
  ncmRange    String?
  cfopList    String?
  state       String?
  icmsRate    Decimal @db.Decimal(8, 4)
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())

  @@map("tax_rules")
}

// ─── Tax Transition Rules ────────────────────────────────────────────────────

model TaxTransitionRule {
  id                          String               @id @default(cuid())
  name                        String
  description                 String?
  stateFrom                   String
  stateTo                     String?
  effectiveFrom               DateTime
  effectiveTo                 DateTime?
  ncmRange                    String?
  cestList                    String?
  cfopList                    String?
  cstList                     String?
  taxRegimeBefore             TaxRegime            @default(ST)
  taxRegimeAfter              TaxRegime            @default(NORMAL)
  calcMethod                  TransitionCalcMethod @default(PROPORTIONAL_ST_ONLY)
  includeFcpStInCredit        Boolean              @default(false)
  requiresExistingStockSnapshot Boolean            @default(true)
  isActive                    Boolean              @default(true)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt

  calculations          CreditCalculation[]
  allocations           StockOriginAllocation[]
  transitionCreditLots  TransitionCreditLot[]

  @@index([stateFrom])
  @@index([isActive])
  @@map("tax_transition_rules")
}

// ─── Transition Credit Lot ───────────────────────────────────────────────────

model TransitionCreditLot {
  id                      String                 @id @default(cuid())
  branchId                String
  calculationId           String?
  snapshotId              String
  stockSnapshotItemId     String
  nfeItemId               String
  taxTransitionRuleId     String
  quantityInStock         Decimal                @db.Decimal(14, 4)
  quantityAllocatedFromNfe Decimal               @db.Decimal(14, 4)
  unitIcmsSt              Decimal                @db.Decimal(14, 6)
  unitFcpSt               Decimal                @db.Decimal(14, 6) @default(0)
  totalIcmsSt             Decimal                @db.Decimal(14, 4)
  totalFcpSt              Decimal                @db.Decimal(14, 4) @default(0)
  creditableAmount        Decimal                @db.Decimal(14, 4)
  nonCreditableAmount     Decimal                @db.Decimal(14, 4) @default(0)
  status                  TransitionCreditStatus @default(OPEN)
  rationale               String?
  executionVersion        Int                    @default(1)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  branch              Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  calculation         CreditCalculation?  @relation(fields: [calculationId], references: [id])
  snapshot            StockSnapshot       @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  stockSnapshotItem   StockSnapshotItem   @relation(fields: [stockSnapshotItemId], references: [id], onDelete: Cascade)
  nfeItem             NfeItem             @relation(fields: [nfeItemId], references: [id], onDelete: Cascade)
  taxTransitionRule   TaxTransitionRule   @relation(fields: [taxTransitionRuleId], references: [id])
  ledgerEntries       TransitionCreditLedgerEntry[]

  @@index([branchId])
  @@index([snapshotId])
  @@index([calculationId])
  @@index([taxTransitionRuleId])
  @@index([status])
  @@map("transition_credit_lots")
}

// ─── Transition Credit Ledger ────────────────────────────────────────────────

model TransitionCreditLedgerEntry {
  id                      String          @id @default(cuid())
  branchId                String
  transitionCreditLotId   String
  entryType               LedgerEntryType
  amount                  Decimal         @db.Decimal(14, 4)
  referenceType           String?
  referenceId             String?
  notes                   String?
  executionVersion        Int             @default(1)
  isAutoGenerated         Boolean         @default(true)
  createdAt               DateTime        @default(now())

  branch              Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  transitionCreditLot TransitionCreditLot @relation(fields: [transitionCreditLotId], references: [id], onDelete: Cascade)

  @@index([branchId])
  @@index([transitionCreditLotId])
  @@index([entryType])
  @@map("transition_credit_ledger_entries")
}

// ─── Credit Calculation ──────────────────────────────────────────────────────

model CreditCalculation {
  id                              String            @id @default(cuid())
  branchId                        String
  kind                            CalculationKind   @default(GENERAL_ICMS)
  mode                            CalculationMode   @default(ASSISTED)
  status                          CalculationStatus @default(PENDING)
  totalStockCost                  Decimal           @db.Decimal(14, 2) @default(0)
  totalIcmsPaid                   Decimal           @db.Decimal(14, 2) @default(0)
  potentialCredit                 Decimal           @db.Decimal(14, 2) @default(0)
  approvedCredit                  Decimal           @db.Decimal(14, 2) @default(0)
  blockedCredit                   Decimal           @db.Decimal(14, 2) @default(0)
  reconciledPct                   Float             @default(0)

  // ST Transition specific
  transitionRuleId                String?
  transitionReferenceDate         DateTime?
  totalIcmsStCredit               Decimal           @db.Decimal(14, 2) @default(0)
  totalFcpStCredit                Decimal           @db.Decimal(14, 2) @default(0)
  totalTransitionCreditGenerated  Decimal           @db.Decimal(14, 2) @default(0)
  totalTransitionCreditBlocked    Decimal           @db.Decimal(14, 2) @default(0)
  totalTransitionCreditAvailable  Decimal           @db.Decimal(14, 2) @default(0)
  executionVersion                Int               @default(1)

  jobError        String?
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime          @default(now())

  branch              Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  transitionRule       TaxTransitionRule?  @relation(fields: [transitionRuleId], references: [id])
  transitionCreditLots TransitionCreditLot[]

  @@index([branchId])
  @@index([kind])
  @@index([transitionRuleId])
  @@map("credit_calculations")
}

// ─── Issues ──────────────────────────────────────────────────────────────────

model Issue {
  id                  String        @id @default(cuid())
  stockSnapshotItemId String?
  severity            IssueSeverity @default(MEDIUM)
  status              IssueStatus   @default(OPEN)
  title               String
  description         String?
  resolution          String?
  resolvedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  stockSnapshotItem StockSnapshotItem? @relation(fields: [stockSnapshotItemId], references: [id])

  @@map("issues")
}

// ─── Dossier ─────────────────────────────────────────────────────────────────

model Dossier {
  id          String        @id @default(cuid())
  branchId    String
  title       String
  status      DossierStatus @default(DRAFT)
  storageKey  String?
  notes       String?
  approvedAt  DateTime?
  approvedBy  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("dossiers")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  companyId  String?
  action     AuditAction
  entity     String
  entityId   String?
  payload    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user    User?    @relation(fields: [userId], references: [id])
  company Company? @relation(fields: [companyId], references: [id])

  @@map("audit_logs")
}
